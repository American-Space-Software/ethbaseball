# syntax=docker/dockerfile:1.7
ARG NODE_VERSION=22.18.0

########### builder ###########
FROM node:${NODE_VERSION}-bookworm-slim AS builder
WORKDIR /app

# Toolchain for native deps your engine uses
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 build-essential git cmake protobuf-compiler \
 && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
# Keep dev deps available during build (you asked not to omit them)
RUN npm ci --no-audit --no-fund

COPY . .
RUN npm run build:engine

# Fail fast if contracts.json not present
RUN test -f ./contracts.json || (echo "contracts.json missing after build. Ensure your build writes it or check it in." >&2; exit 1)

########### runtime ###########
FROM node:${NODE_VERSION}-bookworm-slim AS runtime
WORKDIR /app

# Copy runtime bits
COPY --from=builder /app/package*.json ./ 
COPY --from=builder /app/node_modules   ./node_modules
COPY --from=builder /app/dist           ./dist
COPY --from=builder /app/contracts.json ./contracts.json

# Only the engine prod env file
ARG NODE_ENV
COPY .env.engine.${NODE_ENV} .env


CMD ["node","--env-file=.env","--enable-source-maps","dist/engine.js"]
