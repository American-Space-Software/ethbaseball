{
  "name": "ethbaseball",
  "version": "1.3.0",
  "description": "Ethereum Baseball League (EBL) is a baseball team-management sim. You run a franchise by managing rosters, lineups, and pitching rotations with the goal of winning games and building a strong baseball business.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/American-Space-Software/ethbaseball"
  },
  "scripts": {
    "test": "node --env-file=.env.engine.development ./node_modules/mocha/bin/mocha --timeout 9999999999 --require ts-node/register",
    "test1": "node --env-file=.env.engine.development ./node_modules/mocha/bin/mocha --timeout 9999999999 --require ts-node/register test/test-ladder-service.spec.ts",

    "test:contracts": "export NODE_ENV=development && npx hardhat test test/hardhat/test-diamonds.spec.js",

    "build": "node --loader ts-node/esm node_modules/webpack/bin/webpack.js --config=webpack.prod.ts",
    "build:web": "node --loader ts-node/esm node_modules/webpack/bin/webpack.js --config=webpack.web.ts ",
    "build:engine": "node --loader ts-node/esm node_modules/webpack/bin/webpack.js --config=webpack.discord.ts",
    "build:dev": "node --loader ts-node/esm node_modules/webpack/bin/webpack.js --config=webpack.dev.ts",

    "web": "node --env-file=.env.web.production dist/web-server.js",
    "web:dev": "node --env-file=.env.web.development --enable-source-maps dist/web-server.js --generate true",
    "web:sepolia": "node --env-file=.env.web.sepolia --enable-source-maps dist/web-server.js",

    "engine": "node --env-file=.env.engine.production dist/engine.js",
    "engine:dev": "node --env-file=.env.engine.development --max-old-space-size=4096 dist/engine.js",
    "engine:sepolia": "node --env-file=.env.engine.sepolia --max-old-space-size=4096 dist/engine.js",

    "start": "node --env-file=.env.start.production  dist/index.js",
    "start:dev": "node --env-file=.env.start.development --max-old-space-size=4096 dist/index.js",
    "start:sepolia": "node --env-file=.env.start.sepolia --max-old-space-size=4096 dist/index.js",
    
    "create-car": "node --env-file=.env.start.production  dist/create-car.js",
    "create-car:dev": "node --env-file=.env.start.development  dist/create-car.js",


    "deploy-commands": "node --env-file=.env.production dist/deploy-commands.js",
    

    "docker:build": "sudo NODE_ENV=production docker compose build",

    "docker:compose": "sudo NODE_ENV=production docker compose up --build",
    "docker:compose:dev": "sudo NODE_ENV=development docker compose up --build",
    "docker:compose:sepolia": "sudo NODE_ENV=sepolia docker compose up --build"
    
  },
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "author": "Patrick Toner",
  "bugs": {
    "url": "https://github.com/American-Space-Software/ethbaseball/issues"
  },
  "homepage": "https://github.com/American-Space-Software/ethbaseball#readme",
