# syntax=docker/dockerfile:1.7
ARG NODE_VERSION=22.18.0

########### builder ###########
FROM node:${NODE_VERSION}-bookworm-slim AS builder
WORKDIR /app

# Toolchain for any native deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 build-essential git \
 && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --no-audit --no-fund

# Bring in source and build the web bundles
COPY . .
RUN npm run build:web

# Fail fast if contracts.json isn't present (your web-server reads it)
RUN test -f ./contracts.json || (echo "contracts.json missing after build. Ensure your build produces it or check it into the repo." >&2; exit 1)

########### runtime ###########
FROM node:${NODE_VERSION}-bookworm-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app

# nginx to reverse-proxy :80 -> node :8080
RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

# Minimal nginx.conf (note $$ escapes inside Dockerfile)
# Write Nginx configuration
RUN echo 'worker_processes auto;' > /etc/nginx/nginx.conf && \
    echo 'events { worker_connections 1024; }' >> /etc/nginx/nginx.conf && \
    echo 'http { server { listen 80;' >> /etc/nginx/nginx.conf && \
    echo 'location / { proxy_pass http://localhost:8080;' >> /etc/nginx/nginx.conf && \
    echo 'proxy_set_header Host $host;' >> /etc/nginx/nginx.conf && \
    echo 'proxy_set_header X-Real-IP $remote_addr;' >> /etc/nginx/nginx.conf && \
    echo 'proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;' >> /etc/nginx/nginx.conf && \
    echo 'proxy_set_header X-Forwarded-Proto $scheme;' >> /etc/nginx/nginx.conf && \
    echo '} } }' >> /etc/nginx/nginx.conf
    
# Bring runtime bits from builder
COPY --from=builder /app/package*.json ./ 
COPY --from=builder /app/node_modules   ./node_modules
COPY --from=builder /app/dist           ./dist
COPY --from=builder /app/contracts.json ./contracts.json

# Per your requirement: only the production web env file
ARG NODE_ENV
COPY .env.web.${NODE_ENV} .env

EXPOSE 80
# Start nginx (daemonized by the Debian package) then exec Node
CMD ["sh","-lc","nginx && exec node --env-file=.env --enable-source-maps dist/web-server.js"]
